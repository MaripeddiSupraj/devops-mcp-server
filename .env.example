# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ── Kubernetes ────────────────────────────────────────────────────────────────
KUBECONFIG=/home/yourname/.kube/config

# ── Terraform ─────────────────────────────────────────────────────────────────
TERRAFORM_BINARY=terraform
TERRAFORM_ALLOWED_BASE_DIR=/tmp/terraform
TERRAFORM_TIMEOUT_SECONDS=600

# ── Helm ──────────────────────────────────────────────────────────────────────
HELM_BINARY=helm
HELM_TIMEOUT_SECONDS=300

# ── Azure ─────────────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=my-gcp-project
GOOGLE_APPLICATION_CREDENTIALS=/home/yourname/gcp-service-account.json

# ── ArgoCD ────────────────────────────────────────────────────────────────────
ARGOCD_SERVER_URL=https://argocd.example.com
ARGOCD_AUTH_TOKEN=your-argocd-token
ARGOCD_INSECURE=false

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=your-vault-token
VAULT_NAMESPACE=
VAULT_MOUNT=secret

# ── PagerDuty ─────────────────────────────────────────────────────────────────
PAGERDUTY_API_KEY=your-pagerduty-api-key
PAGERDUTY_EMAIL=oncall@example.com
PAGERDUTY_SERVICE_ID=PXXXXXX

# ── Slack (optional) ──────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# Set to true to block all mutating operations (safe for testing)
DRY_RUN=false

# Require Authorization: Bearer <key> on all requests (leave unset for dev)
# MCP_API_KEY=your-secret-api-key

# Comma-separated allowed CORS origins. Use * for local dev only.
CORS_ORIGINS=*

# SQLite audit log path
AUDIT_DB_PATH=audit.db

# Per-tool execution timeout in seconds (0 = no timeout)
TOOL_TIMEOUT_SECONDS=120
